# ---------------------------------------------------------------------------
# Template for local environment config. Copy to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real credentials.
# ---------------------------------------------------------------------------

# --- Azure PostgreSQL (owner-provided, for local debugging) ---
PGHOST=pmdb.postgres.database.azure.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=CHANGME_username         # Flexible Server: "myadmin"  |  Single Server: "myadmin@pmdb"
PGPASSWORD=CHANGEME_password
PGSSLMODE=require

# Convenience: full connection string (some tools read this instead of the parts above)
DATABASE_URL=postgresql://CHANGEME_username:CHANGEME_password@pmdb.postgres.database.azure.com:5432/postgres?sslmode=require

# --- Email OTP delivery (Azure Communication Services) ---
# Both blank → OTP codes are dev-logged only (no email sent). Set both to send
# real verification emails. Create an ACS resource + Email Communication Service
# with a verified sender domain, then paste the connection string and sender.
ACS_EMAIL_CONNECTION_STRING=          # endpoint=https://<acs>.communication.azure.com/;accesskey=...
ACS_EMAIL_SENDER=                     # DoNotReply@<your-verified-domain>
# APP_NAME=Project Management         # optional; shown in the OTP email subject/body

# --- AI / chat agent (Phase 2) ---
GEMINI_API_KEY=              # Google AI Studio key; blank disables the chat agent
# GEMINI_MODEL=gemini-flash-latest   # optional override (default tracks current stable Flash)

# --- Deferred until later phases (leave blank for now) ---
# SMS_PROVIDER_KEY=          # SMS OTP delivery, second channel (later)
